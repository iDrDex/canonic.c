  # reader never lingers on the tsv fallback longer than the compact itself.
  "$ROOT/libexec/bake" "$IDX" "$PARENTS" >/dev/null 2>&1 || true
  echo "compact · tail folded · $(wc -l < "$IDX/term.off" | tr -d ' ') terms keyed"
  ;;
svd)
  # CHAIN-NATIVE MANIFOLD (the corrected lift): learn the lens FROM the chain itself — PPMI + SVD
  # word vectors over every clause (no external model, chip.chain.brain). chunk vec = idf-weighted
  # mean of word vecs; parent vec = mean of its chunk vecs. Evaluates fold-sibling retrieval
  # (apples-to-apples vs the refuted 0.020 baseline). Derived artifacts: index/svd/*.
  SD="$ROOT/index/svd"; mkdir -p "$SD"
  CH="$IDXR/chunks.tsv"; [ -s "$CH" ] || { echo "coalesce svd: no chunks.tsv" >&2; exit 69; }
