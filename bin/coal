  open my $MF,'<',"$ND/nanodex.mean"; my @mu=split / /,<$MF>; close $MF;
  open my $EF,'<',"$ND/nanodex.eig";  my @ev=split / /,<$EF>; close $EF;
  $d=@mu;
  if(@qw==$d){
    $qw[$_]-=$mu[$_] for 0..$d-1;
    my $dp=0; $dp+=$qw[$_]*$ev[$_] for 0..$d-1; $qw[$_]-=$dp*$ev[$_] for 0..$d-1;
    # THE LEARNED LENS (chain-supervised): drop the style/noise PCs from the query too — the
    # baked doc space (nanodex.lens.bin) and the query must share one geometry.
    if(-s "$NDC/lens.pcs" && -s "$NDC/lens.drop" && -s "$ND/nanodex.lens.bin"){
