    open my $LS,'-|',"grep -E '^($pat) ' '$ND/nanodex.lsh'" or die;
    while(<$LS>){ chomp; my(undef,$r)=split / /; push @rows,$r unless $seen{$r}++ }
    close $LS;
  } else { @rows = 0..$#NH }
