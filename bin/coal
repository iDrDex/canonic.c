my($dir,$pf,$Q)=@ARGV; my $K=$ENV{K}||1; my $QV=$ENV{QVEC}//''; my $ND=$ENV{NDX}//''; my $LED=$ENV{LEDF}//'';
sub toks{ my $s=lc(shift); $s=~s/[^a-z0-9]+/ /g; return grep{length} split / /,$s }
