my %cand; my $r=0;
for my $p (@brank){ last if $r++>=100; $cand{$ph[$p]}=1 if $ph[$p] }
my $row=4*($d//0); my $BFH;
sub cosof{ my $h=shift; return $cosr{$h} if exists $cosr{$h}; return 0 unless $sem && exists $hrow{$h};
  unless($BFH){ open $BFH,'<:raw',$BIN or return 0 }
  my $buf; sysseek($BFH,$hrow{$h}*$row,0); sysread($BFH,$buf,$row)==$row or return 0;
  my @w=unpack("f$d",$buf); my $c=0; $c+=$w[$_]*$qx[$_] for 0..$d-1; $cosr{$h}=$c>0?$c:0; $cosr{$h} }
if($sem && $conf<1){
  # weak lexical spine -> BFS the manifold. ON-CHIP LSH when baked (bucket candidates only,
  # ~100 exact cosines instead of 30k); full scan is the fallback for an unbaked index.
  my @rows;
  if($lensed && -s "$ND/nanodex.lsh"){
    my($L,$B)=(10,12); my @keys;
    for my $t (0..$L-1){ my $key=0;
