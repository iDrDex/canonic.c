#!/bin/sh
# ATOM: INTEL — the MCI/knowledge engine; the index IS the intel face. BEAT (b5·B) lives here.
# the intel face: the MCI engine — knowledge coalesced into the λ-registry; one of the three faces of the one conserved primitive.
# coal — DERIVED recall sidecar (never writes the chain). Chunk each NANO fold into atomic
# clauses + a BM25 inverted index, so a single distinctive clause surfaces its fold regardless of
# the omnibus doc's length — fixing bin/laude's un-normalized word-overlap length bias.
# verbs:  coalesce build            (chip: re-index ~/forge/LEDGER over the live chain)
#         coalesce recall <query>   (brain: BM25 max-chunk; laude-style attest line)
# Validated /tmp/coalesce impl (chunk.pl+build_index.pl+q.pl); materialized verbatim.
set -u
ROOT="$HOME/.canonic"
LED="$HOME/.canonic/LEDGER/closure/events.jsonl"; [ -f "$LED" ] || LED="$HOME/forge/LEDGER/closure/events.jsonl"
IDXR="${COALESCE_IDXR:-$ROOT/index/coalesce}"; PARENTS="$IDXR/parents.tsv"; IDX="$IDXR/idx"
verb="${1:-beat}"; shift 2>/dev/null || true

case "$verb" in
beat)
  # THE BEAT is coalesce's default verb (the 8-verb kernel: coalesce = BEAT = the b5 bit).
  # The engine's beat orchestrates: inc index catch-up + docs gating + pulse + fleet drain.
  exec "$HOME/.canonic/libexec/canonic" beat ;;
build)
  # --inc (R6, the beat): append-index ONLY the events past .thru — fold -> recallable in one beat.
  if [ "${1:-}" = "--inc" ]; then
    # no index OR no .thru watermark -> full build (an inc from 0 would double-index the chain)
    [ -s "$IDX/stats" ] && [ -s "$IDXR/.thru" ] || exec "$0" build
    thru=$(cat "$IDXR/.thru" 2>/dev/null || echo 0)
    total=$(wc -l < "$LED" | tr -d ' ')
    [ "$total" -gt "$thru" ] || {
      # on-tip: the docs tier is vacuously current too — wear the tip (the qed gap measure
      # reads the stamp, and a gated rebuild no longer restamps every beat)
      cat "$HOME/forge/LEDGER/HEAD" > "$ROOT/index/docs/.tip" 2>/dev/null
      printf '%s\n' "$total" > "$ROOT/index/docs/.thru" 2>/dev/null
      echo "coalesce inc: on-tip ($total)"; exit 0; }
    NEW=$(mktemp)
    tail -n +"$((thru+1))" "$LED" | jq -rc 'select((.payload_hash? // "" | length) == 64) | [ .payload_hash, (.payload.formal // (.payload | del(.category?) | tostring)) ] | @tsv' > "$NEW"
    # NATIVE SOV (R8): CAS-decode ##-folds in NEW too (same as full build) so coverage sees prose
    perl -e 'my($pf)=@ARGV; open my $P,"<",$pf or die; my @o;
      while(<$P>){ chomp; my($h,$f)=split/\t/,$_,2; next unless defined $f;
        if($f=~/^#(?:chat|fs|mem|doc|law|axiom|vocab|kernel|lang|alias|decomp|runtime|anchor|ln|ATOMIC)\b/ && $f=~/\|\s*([0-9a-f]{64})$/){ my $c="$ENV{HOME}/forge/cas/objects/$1";
          if(-f $c){ local $/; open my $C,"<",$c; my $p=<$C>; close $C; $p=~s/\s+/ /g; $f=~s/[0-9a-f]{64}$//; $f.=$p; } }
        push @o,"$h\t$f\n"; } close $P; open my $W,">",$pf or die; print $W @o; close $W;' "$NEW"
    if [ -s "$NEW" ]; then
      pbase=$(wc -l < "$PARENTS" | tr -d ' ')
      cat "$NEW" >> "$PARENTS"
      # chunk + append postings/meta + merge df + refresh stats (same algebra as full build)
      perl /dev/stdin "$NEW" "$pbase" "$IDXR" <<'PL'
use strict; use warnings; my($nf,$pbase,$idxr)=@ARGV; my $dir="$idxr/idx";
sub toks{ my $s=lc(shift); $s=~s/[^a-z0-9]+/ /g; grep{length} split / /,$s }
my %stats; open my $S,'<',"$dir/stats"; while(<$S>){chomp;my($k,$v)=split/=/;$stats{$k}=$v} close $S;
my $N=$stats{N}; my $tot=$stats{avg}*$N;
my %df; open my $D,'<',"$dir/df.tsv"; while(<$D>){chomp;my($t,$c)=split/\t/;$df{$t}=$c} close $D;
open my $NF,'<',$nf or die; open my $POST,'>>',"$dir/post.tail"; open my $META,'>>',"$dir/meta.tsv";
my $pidx=$pbase; my $MIN=24; my $MAX=320; my $cadd=0;
while(my $line=<$NF>){ chomp $line; $pidx++; my($h,$formal)=split/\t/,$line,2; next unless defined $formal;
  my $t=$formal; $t=~s/\s+/ /g; $t=~s/^\s+//; $t=~s/\s+$//;
  # prose IS #: a ##-fold (#chat/#fs ... | <64hex>) carries its prose in the CAS — index THAT,
  # keyed to the chain ## ($h). The chain stays pure #; the brain reads the prose it addresses.
  if($t=~/^#(?:chat|fs|mem|doc|law|axiom|vocab|kernel|lang|alias|decomp|runtime|anchor|ln|ATOMIC)\b/ && $t=~/\|\s*([0-9a-f]{64})$/){ my $c="$ENV{HOME}/forge/cas/objects/$1";
    if(-f $c){ local $/; open my $C,'<',$c; my $p=<$C>; close $C; $p=~s/\s+/ /g; $t=~s/[0-9a-f]{64}$//; $t.=$p; } }
  my @raw=split /(?<=[.;!?])\s+|\n|\s+[\x{2014}\x{2013}]\s+|\s+-\s+/, $t; my @chunks; my $buf="";
  for my $seg (@raw){ $seg=~s/^\s+//; $seg=~s/\s+$//; next if $seg eq "";
    if(length($buf)==0){$buf=$seg} elsif(length($buf)<$MIN){$buf.=" ".$seg} else{push @chunks,$buf;$buf=$seg} }
  push @chunks,$buf if length($buf); my @out;
  for my $ch (@chunks){ while(length($ch)>$MAX){push @out,substr($ch,0,$MAX);$ch=substr($ch,$MAX)} push @out,$ch if length($ch) }
  @out=($t) unless @out;
  for my $ch (@out){ $N++; $cadd++; my @tk=toks($ch); my %tf; $tf{$_}++ for @tk; my $dl=@tk; $tot+=$dl;
    print $META "$N\t$pidx\t$dl\n"; for my $w (keys %tf){ $df{$w}++; print $POST "$w\t$N\t$tf{$w}\n" } } }
close $POST; close $META;
open my $DO,'>',"$dir/df.tsv"; print $DO "$_\t$df{$_}\n" for keys %df; close $DO;
open my $SO,'>',"$dir/stats"; printf $SO "N=%d\navg=%s\n",$N,($N?$tot/$N:0); close $SO;
print STDERR "inc: +$cadd chunks (N=$N)\n";
PL
      # SUPERSESSION RIDES THE INC (P3): a re-folded NAMED knowledge fold is a REGISTER write —
      # the fossil's parent record is TOMBSTONED in place (bake -tomb pokes one byte) and logged
      # in idx/tombs so every future bake re-applies it. The chain keeps both folds (append-only);
      # the read path answers with the latest binding only. Keyed exactly like supersede_names.
      NN=$(mktemp)
      LC_ALL=C awk -F'\t' -v base="$pbase" '{ f=$2; key=""
          if (f ~ /^#(law|axiom|vocab|kernel|decomp|lang) [^|]+\|/) { split(f,a,"|"); key="N:" a[1] }
          else if (f ~ /^#alias .* = /) { split(f,a," = "); key="A:" a[1] }
          if (key!="") printf "%s\t%d\n", key, base+NR }' "$NEW" > "$NN"
      if [ -s "$NN" ]; then
        touch "$IDX/names.tsv"
        FOS=$(awk -F'\t' 'NR==FNR{new[$1]=1;next} ($1 in new){print $2}' "$NN" "$IDX/names.tsv")
        if [ -n "$FOS" ]; then
          printf '%s\n' "$FOS" >> "$IDX/tombs"
          "$ROOT/libexec/bake" -tomb "$IDX" $FOS >/dev/null 2>&1 || true
        fi
        awk -F'\t' 'NR==FNR{new[$1]=1;next} !($1 in new)' "$NN" "$IDX/names.tsv" > "$IDX/names.tsv.tmp"
        cat "$NN" >> "$IDX/names.tsv.tmp"; mv "$IDX/names.tsv.tmp" "$IDX/names.tsv"
      fi
      rm -f "$NN"
    fi
    # SEMANTIC TIER STAYS ON-TIP (chip.chain.brain): embed each new fold -> transform -> append
    # raw + lensed rows + LSH bucket lines. The brain grows one beat at a time, never a rebuild.
    ND="$ROOT/index/nanodex"; NDC="$ROOT/index/nanodexc"
    if [ -s "$NEW" ] && [ -s "$ND/nanodex.bin" ] && [ -x "$ROOT/libexec/embed" ]; then
      perl /dev/stdin "$NEW" "$ND" "$NDC" "$ROOT/libexec/embed" <<'PL' || true
use strict; use warnings;
my($nf,$ND,$NDC,$EMBED)=@ARGV;
open my $MF,'<',"$ND/nanodex.mean" or exit; my @mu=split / /,<$MF>; close $MF;
open my $EF,'<',"$ND/nanodex.eig" or exit;  my @ev=split / /,<$EF>; close $EF;
my $d=@mu;
my (@E,@drop);
if(-s "$NDC/lens.pcs" && -s "$NDC/lens.drop"){
  open my $PC,'<',"$NDC/lens.pcs"; while(<$PC>){chomp; push @E,[split / /]} close $PC;
  open my $DR,'<',"$NDC/lens.drop"; my $dl=<$DR>//''; chomp $dl; @drop=grep{length}split / /,$dl; close $DR;
}
my %st; open my $S,'<',"$ND/stats"; while(<$S>){chomp;my($k,$v)=split/=/;$st{$k}=$v} close $S;
my $r0=$st{rows};
open my $NF2,'<:raw',$nf or exit; my (@H,@T);
while(<$NF2>){ chomp; my($h,$t)=split /\t/,$_,2; next unless defined $t && $h=~/^[0-9a-f]{64}$/;
  $t=substr($t,0,1200); $t=~s/\x0/ /g; push @H,$h; push @T,$t }
close $NF2; exit unless @H;
open my $EP,'|-',"$EMBED > '$ND/.inc.vec' 2>/dev/null" or exit;
print $EP "$_\0" for @T; close $EP;
open my $VF,'<',"$ND/.inc.vec" or exit; my @V=<$VF>; chomp @V; close $VF; unlink "$ND/.inc.vec";
open my $HO,'>>',"$ND/nanodex.hash"; open my $BO,'>>:raw',"$ND/nanodex.bin";
my $LB; my $LL; my($L,$B)=(10,12);
if(-s "$ND/nanodex.lens.bin"){ open $LB,'>>:raw',"$ND/nanodex.lens.bin"; open $LL,'>>',"$ND/nanodex.lsh" }
my $added=0;
for my $i (0..$#H){
  my $v=$V[$i]//''; next if $v eq 'MISS' || $v!~/ /;
  my @w=split / /,$v; next unless @w==$d;
  $w[$_]-=$mu[$_] for 0..$d-1;
  my $dp=0; $dp+=$w[$_]*$ev[$_] for 0..$d-1; $w[$_]-=$dp*$ev[$_] for 0..$d-1;
  my $nn=0;$nn+=$_*$_ for @w;$nn=sqrt($nn)||1;$_/=$nn for @w;
  print $HO "$H[$i]\n"; print $BO pack("f*",@w); my $ri=$r0+$added; $added++;
  if($LB){
    my @z=@w;
    for my $j (@drop){ my $ej=$E[$j]; my $dp2=0; $dp2+=$z[$_]*$ej->[$_] for 0..$d-1; $z[$_]-=$dp2*$ej->[$_] for 0..$d-1 }
    my $n2=0;$n2+=$_*$_ for @z;$n2=sqrt($n2)||1;$_/=$n2 for @z;
    print $LB pack("f*",@z);
    for my $t (0..$L-1){ my $key=0;
      for my $j (0..$B-1){ my $pi=$t*$B+$j; my $dp3=0;
        for my $ii (0..$d-1){ my $hh=($pi*2654435761 + $ii*40503 + 0x5CA1AB1E) % 0xFFFFFFFF;
          $dp3 += $z[$ii] * ((($hh>>16)&1)?1:-1) }
        $key=($key<<1)|($dp3>=0?1:0) }
      print $LL "$t:$key $ri\n" }
  }
}
close $HO; close $BO; $LB and close $LB; $LL and close $LL;
open my $SO,'>',"$ND/stats"; printf $SO "rows=%d\ndim=%d\nmiss=%d\n",$r0+$added,$d,$st{miss}//0; close $SO;
print STDERR "inc-nanodex: +$added rows\n";
PL
    fi
    # DELTA TAIL (P1, kills the per-fold 141MB sort): postings append to idx/post.tail; the native
    # reader scans the tail linearly alongside the term.off seeks, so a fresh fold is recallable
    # THIS beat with NO re-sort. compact (merge tail -> post.sorted, regen term.off) runs only
    # when the tail crosses the threshold — backgrounded, locked, atomic.
    if [ -f "$IDX/post.tail" ] && [ "$(wc -c < "$IDX/post.tail" | tr -d ' ')" -gt "${COALESCE_TAILMAX:-16777216}" ]; then
      ( "$0" compact >/dev/null 2>&1 & )
    fi
    # DOCS TIER RIDES THE INC (P1, kills the per-fold full-ledger jq): only when a KNOWLEDGE fold
    # actually landed (or the docs tier is absent) does the tiny docs index rebuild — from its own
    # ~200-line parents surface merged with the new knowledge lines, never from the 141MB ledger.
    # Foreground: a tiny index must never be raced (the 2026-07-12 torn-docs scar).
    tab=$(printf '\t')
    if [ ! -s "$ROOT/index/docs/idx/stats" ] || grep -qE "${tab}#(law|axiom|vocab|kernel|alias|decomp|lang|ATOMIC)" "$NEW" 2>/dev/null; then
      dmerge=$(mktemp)
      cat "$ROOT/index/docs/parents.tsv" 2>/dev/null > "$dmerge"
      grep -E "${tab}#(law|axiom|vocab|kernel|alias|decomp|lang|ATOMIC)" "$NEW" >> "$dmerge" 2>/dev/null || true
      COALESCE_IDXR="$ROOT/index/docs" COALESCE_SCOPE=docs COALESCE_FROM="$dmerge" "$0" build >/dev/null 2>&1 || true
      rm -f "$dmerge"
    else
      # VACUOUSLY CURRENT: no knowledge fold landed, so the docs tier's CONTENT is already at
      # tip — stamp it so the qed gap measure sees the truth (the old per-beat rebuild stamped
      # every beat; a gated rebuild must still wear the tip it reflects).
      cat "$HOME/forge/LEDGER/HEAD" > "$ROOT/index/docs/.tip" 2>/dev/null
      printf '%s\n' "$total" > "$ROOT/index/docs/.thru" 2>/dev/null
    fi
    rm -f "$NEW"
    cat "$HOME/forge/LEDGER/HEAD" > "$IDXR/.tip" 2>/dev/null   # THE SOV BIT (inc path too)
    printf '%s\n' "$total" > "$IDXR/.thru"
    echo "coalesce inc: indexed thru $total"
    exit 0
  fi
  mkdir -p "$IDX"
  # STAGED + LOCKED, PUBLISHED ATOMICALLY (the torn-index scar, 2026-07-12): every fold beats a
  # docs rebuild, and this jq dumps the FULL ledger before the scope filter runs — a reader
  # (laude tier-0) catching that window saw a 71k-line unscoped parents.tsv; two OVERLAPPING
  # builds sharing one staging path then published each other's empties (parents=0). So:
  # ONE builder per IDXR (mkdir lock — losers skip, the next beat converges freshness),
  # $$-unique staging, and readers only ever see a complete surface via atomic mv.
  BLOCK="$IDXR/.build.lock"
  if ! mkdir "$BLOCK" 2>/dev/null; then echo "coalesce build: another builder holds $BLOCK, skipping" >&2; exit 0; fi
  trap 'rmdir "$BLOCK" 2>/dev/null' EXIT INT TERM
  STG="$PARENTS.new.$$"; DSTG=""
  # parents: payload_hash \t formal  (one NANO per line; @tsv escapes embedded tabs/newlines)
  # COALESCE_FROM (P1): build from a supplied parents-format surface instead of scanning the full
  # ledger — the docs tier refreshes from its own ~200 lines + the beat's new knowledge folds.
  if [ -n "${COALESCE_FROM:-}" ] && [ -f "$COALESCE_FROM" ]; then
    cat "$COALESCE_FROM" > "$STG"
  else
    jq -rc 'select((.payload_hash? // "" | length) == 64) | [ .payload_hash, (.payload.formal // (.payload | del(.category?) | tostring)) ] | @tsv' "$LED" > "$STG"
  fi
  # SUPERSESSION (the matmul-fossil scar): a NAMED knowledge fold is a REGISTER — '#law x | …'
  # re-folded means the old binding is superseded. The chain keeps both (append-only, SOT);
  # the DERIVED knowledge index carries only the LATEST per name, or the fossil outranks the
  # fresh fold on bm25 length-norm forever. Keyed on '#tag name |' and '#alias lhs ='; unnamed
  # folds pass through untouched. Ledger order = chronological, so last line wins.
  supersede_names() {
    awk -F'\t' '{ f=$2; key=""
        if (f ~ /^#(law|axiom|vocab|kernel|decomp|lang) [^|]+\|/) { split(f,a,"|"); key="N:" a[1] }
        else if (f ~ /^#alias .* = /)                            { split(f,a," = "); key="A:" a[1] }
        else key="H:" NR
        if (!(key in ord)) ord[key]=++n
        line[key]=$0 }
      END { for (k in ord) out[ord[k]]=line[k]; for (i=1;i<=n;i++) if (i in out) print out[i] }'
  }
  # SCOPE BEATS SIZE: COALESCE_SCOPE=docs builds THE NANO DOCS index — only the KNOWLEDGE folds
  # (law · axiom · vocab · kernel · alias · decomp ≈ 174) instead of the full 196k. The knowledge
  # is 1.4% of the corpus; BM25 over everything drowns each law in the 12k chat transcripts that
  # merely MENTION it. laude asks THIS index first. (the "what is the fold" → transcript scar)
  if [ "${COALESCE_SCOPE:-}" = docs ]; then
    tab=$(printf '\t')
    grep -E "${tab}#(law|axiom|vocab|kernel|alias|decomp|lang|ATOMIC)" "$STG" > "$STG.d" || : > "$STG.d"
    supersede_names < "$STG.d" > "$STG"
    rm -f "$STG.d"
  fi
  # NATIVE SOV (R8): CAS-decode ##-folds IN parents.tsv so bm25.c's coverage floor sees the PROSE
  # (prefix retained -> public gate still strips; chain stays pure #, the derived index carries prose).
  perl -e 'my($pf)=@ARGV; open my $P,"<",$pf or die; my @o;
    while(<$P>){ chomp; my($h,$f)=split/\t/,$_,2; next unless defined $f;
      if($f=~/^#(?:chat|fs|mem|doc|law|axiom|vocab|kernel|lang|alias|decomp|runtime|anchor|ln|ATOMIC)\b/ && $f=~/\|\s*([0-9a-f]{64})$/){ my $c="$ENV{HOME}/forge/cas/objects/$1";
        if(-f $c){ local $/; open my $C,"<",$c; my $p=<$C>; close $C; $p=~s/\s+/ /g; $f=~s/[0-9a-f]{64}$//; $f.=$p; } }
      push @o,"$h\t$f\n"; } close $P; open my $W,">",$pf or die; print $W @o; close $W;' "$STG"
  # ── THE NANO DOCS (scope beats size): a SECOND, tiny corpus of only the KNOWLEDGE folds —
  # law · axiom · vocab · kernel · alias · decomp (~174, vs 12k chat = the knowledge is 1.4%).
  # laude searches THIS first; the full corpus is the fallback. Without it, BM25 drowns every
  # law in the chatter that merely mentions it (the "what is the fold" → a transcript scar).
  DOCS="$IDXR/parents-docs.tsv"; DSTG="$DOCS.new.$$"
  grep -E "$(printf '\t')#(law|axiom|vocab|kernel|alias|decomp|lang|ATOMIC)" "$STG" 2>/dev/null \
    | supersede_names > "$DSTG" || : > "$DSTG"
  perl -e 'my($pf)=@ARGV; open my $P,"<",$pf or die; my @o;
    while(<$P>){ chomp; my($h,$f)=split/\t/,$_,2; next unless defined $f;
      if($f=~/\|\s*([0-9a-f]{64})\s*$/){ my $c="$ENV{HOME}/forge/cas/objects/$1";
        if(-f $c){ local $/; open my $C,"<",$c; my $p=<$C>; close $C; $p=~s/\s+/ /g; $f=~s/[0-9a-f]{64}\s*$//; $f.=$p; } }
      push @o,"$h\t$f\n"; } close $P; open my $W,">",$pf or die; print $W @o; close $W;' "$DSTG"
  # PUBLISH (atomic, same fs): readers only ever see a complete parents/docs surface.
  mv "$DSTG" "$DOCS"
  mv "$STG" "$PARENTS"
  # NAME REGISTRY + TOMBS (P3): rebuilt from zero with the surface (line indices changed).
  # names.tsv: key -> LATEST parent line; tombs: every superseded (fossil) line, consumed by bake.
  LC_ALL=C awk -F'\t' -v names="$IDX/names.tsv.tmp" -v tombs="$IDX/tombs.tmp" 'BEGIN{ printf "" > tombs }
    { f=$2; key=""
      if (f ~ /^#(law|axiom|vocab|kernel|decomp|lang) [^|]+\|/) { split(f,a,"|"); key="N:" a[1] }
      else if (f ~ /^#alias .* = /) { split(f,a," = "); key="A:" a[1] }
      if (key!="") { if (key in last) print last[key] >> tombs; last[key]=NR } }
    END{ for (k in last) printf "%s\t%d\n", k, last[k] > names }' "$PARENTS" 2>/dev/null || true
  mkdir -p "$IDX"; mv -f "$IDX/names.tsv.tmp" "$IDX/names.tsv" 2>/dev/null; mv -f "$IDX/tombs.tmp" "$IDX/tombs" 2>/dev/null
  echo "coalesce docs · $(wc -l < "$DOCS" | tr -d ' ') nano-docs (the knowledge scope)" >&2
  cat "$HOME/forge/LEDGER/HEAD" > "$IDXR/.tip" 2>/dev/null   # THE SOV BIT: the surface stamps the HEAD it projects
  wc -l < "$LED" | tr -d ' ' > "$IDXR/.thru"
  np=$(wc -l < "$PARENTS" | tr -d ' ')
  # chunk parents -> clauses
  perl /dev/stdin "$PARENTS" "$IDXR/chunks.tsv" <<'PL'
use strict; use warnings; my($pf,$cf)=@ARGV;
open my $P,'<',$pf or die; open my $C,'>',$cf or die; my $cid=0; my $pidx=0; my $MIN=24; my $MAX=320;
while(my $line=<$P>){ chomp $line; $pidx++; my($h,$formal)=split /\t/,$line,2; next unless defined $formal;
  my $t=$formal; $t=~s/\s+/ /g; $t=~s/^\s+//; $t=~s/\s+$//;
  # prose IS # (see --inc chunker): pull a ##-fold's prose from the CAS, index it under the chain #.
  if($t=~/^#(?:chat|fs|mem|doc|law|axiom|vocab|kernel|lang|alias|decomp|runtime|anchor|ln|ATOMIC)\b/ && $t=~/\|\s*([0-9a-f]{64})$/){ my $c="$ENV{HOME}/forge/cas/objects/$1";
    if(-f $c){ local $/; open my $CB,'<',$c; my $p=<$CB>; close $CB; $p=~s/\s+/ /g; $t=~s/[0-9a-f]{64}$//; $t.=$p; } }
  $t=~s/\s+(\(\d+\))/\n$1/g;
  my @raw=split /(?<=[.;!?])\s+|\n|\s+[\x{2014}\x{2013}]\s+|\s+-\s+/, $t; my @chunks; my $buf="";
  for my $seg (@raw){ $seg=~s/^\s+//; $seg=~s/\s+$//; next if $seg eq "";
    if(length($buf)==0){$buf=$seg} elsif(length($buf)<$MIN){$buf.=" ".$seg} else{push @chunks,$buf; $buf=$seg} }
  push @chunks,$buf if length($buf); my @out;
  for my $ch (@chunks){ while(length($ch)>$MAX){push @out,substr($ch,0,$MAX); $ch=substr($ch,$MAX)} push @out,$ch if length($ch) }
  @out=($t) unless @out; for my $ch (@out){ $ch=~s/\t/ /g; $cid++; print $C "$cid\t$pidx\t$ch\n" } }
close $C; print STDERR "chunks=$cid parents=$pidx\n";
PL
  # BM25 inverted index
  perl /dev/stdin "$IDXR/chunks.tsv" "$IDX" <<'PL'
use strict; use warnings; my($cf,$dir)=@ARGV; mkdir $dir unless -d $dir;
sub toks{ my $s=lc(shift); $s=~s/[^a-z0-9]+/ /g; return grep{length} split / /,$s }
open my $C,'<',$cf or die; open my $POST,'>',"$dir/post.tsv"; open my $META,'>',"$dir/meta.tsv";
my %df; my $tot=0; my $n=0;
while(<$C>){ chomp; my($id,$par,$tx)=split/\t/,$_,3; $n++; my @t=toks($tx//""); my %tf; $tf{$_}++ for @t; my $dl=@t; $tot+=$dl;
