# ---- SPECTRAL BFS on the lexical spine (R5): evidence-weighted — the exact signal GATES how far
# the fuzzy frontier may wander. Strong BM25 (top>=8) = lexical wins, spectral only re-ranks its
# candidates. Weak BM25 = attention fans wide (full manifold scan). Lexical exact match wins ties.
my $sem=0; my (%cosr, @qx, $d, @NH); my $NDC=$ENV{NDC}//''; my $BIN="$ND/nanodex.bin"; my $lensed=0;
if ($QV=~/ / && -s "$ND/nanodex.bin"){
