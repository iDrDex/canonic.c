use strict; use warnings;
my($cf,$pf,$SD,$DIMS)=@ARGV;
sub toks{ my $s=lc(shift); $s=~s/[^a-z0-9]+/ /g; grep{length>2} split / /,$s }
# ---- pass 1: counts (word df, word-in-chunk occurrences) ----
my (%df,%tf); my $NC=0;
open my $C,'<:raw',$cf or die;
my (@cpar,@ctoks);
while(<$C>){ chomp; my($id,$par,$tx)=split/\t/,$_,3; $NC++;
  my @t=toks($tx//""); my %u; $u{$_}++ for @t;
  push @cpar,$par; push @ctoks,[%u];
  for my $w (keys %u){ $df{$w}++; $tf{$w}+=$u{$w} } }
close $C;
# vocab: keep words 5 <= df <= NC/10 (drop hapax + stopwords)
my %vid; my @vw; for my $w (sort keys %df){ next if $df{$w}<5 || $df{$w}>$NC/10; $vid{$w}=@vw; push @vw,$w }
my $V=@vw; print "svd: chunks=$NC vocab=$V dims=$DIMS\n";
# ---- PPMI rows per chunk (sparse) ----
# ppmi(w,c-context) approximated at chunk granularity: weight = idf(w) (cheap, retrieval-oriented)
my %idf; $idf{$_}=log($NC/$df{$vw[$vid{$_}]}) for keys %vid;
# sparse chunk-term matrix: rows = chunks, cols = vocab, val = (1+log tf) * idf
my (@rowptr,@colid,@val); my $nz=0;
for my $ci (0..$NC-1){
  push @rowptr,$nz; my %u=@{$ctoks[$ci]};
  for my $w (keys %u){ next unless exists $vid{$w};
    push @colid,$vid{$w}; push @val,(1+log($u{$w}))*$idf{$w}; $nz++ } }
push @rowptr,$nz; @ctoks=();
print "svd: nonzeros=$nz\n";
# ---- top-DIMS right singular vectors of X (vocab-space) via power iteration on X^T X ----
my @U;  # vocab x DIMS
for my $k (0..$DIMS-1){
  my @v=map{ (($_*2654435761+$k*613)%1000)/1000-0.5 }(0..$V-1);
  for my $it (0..9){
    my @xu=(0)x$NC;
    for my $ci (0..$NC-1){ my $s=0;
      for my $p ($rowptr[$ci]..$rowptr[$ci+1]-1){ $s+=$val[$p]*$v[$colid[$p]] } $xu[$ci]=$s }
    my @nv=(0)x$V;
    for my $ci (0..$NC-1){ my $u=$xu[$ci]; next unless $u;
      for my $p ($rowptr[$ci]..$rowptr[$ci+1]-1){ $nv[$colid[$p]]+=$val[$p]*$u } }
    for my $pe (@U){ my $dp=0; $dp+=$nv[$_]*$pe->[$_] for 0..$V-1; $nv[$_]-=$dp*$pe->[$_] for 0..$V-1 }
    my $nn=0;$nn+=$_*$_ for @nv;$nn=sqrt($nn)||1;@v=map{$_/$nn}@nv;
  }
  push @U,[@v];
  print "svd: dim $k\n" if $k%8==7;
}
# ---- word vectors -> chunk vectors -> parent vectors ----
open my $WO,'>',"$SD/words.tsv"; for my $w (sort{$vid{$a}<=>$vid{$b}} keys %vid){ print $WO "$w\n" } close $WO;
open my $UO,'>:raw',"$SD/wordvec.bin";
for my $wi (0..$V-1){ my @wv=map{$U[$_][$wi]}0..$DIMS-1; print $UO pack("f*",@wv) } close $UO;
# parent vectors: sum of chunk vecs (chunk vec = X row * U), normalized
open my $PF2,'<',$pf or die; my @phash; my $pi=0; while(<$PF2>){chomp; my($h)=split/\t/,$_,2; $phash[++$pi]=$h} close $PF2;
my %pv;
for my $ci (0..$NC-1){
  my @cv=(0)x$DIMS;
  for my $p ($rowptr[$ci]..$rowptr[$ci+1]-1){ my $w=$colid[$p]; my $x=$val[$p];
    $cv[$_]+=$x*$U[$_][$w] for 0..$DIMS-1 }
  my $par=$cpar[$ci]; $pv{$par}//=[(0)x$DIMS];
  $pv{$par}[$_]+=$cv[$_] for 0..$DIMS-1;
}
open my $PO,'>',"$SD/parent.hash"; open my $PB,'>:raw',"$SD/parent.bin"; my $np=0;
for my $par (sort{$a<=>$b} keys %pv){
  my $h=$phash[$par]//next; my $v=$pv{$par};
  my $nn=0;$nn+=$_*$_ for @$v;$nn=sqrt($nn)||1;
  print $PO "$h\n"; print $PB pack("f*",map{$_/$nn}@$v); $np++;
}
close $PO; close $PB;
open my $ST,'>',"$SD/stats"; print $ST "parents=$np\ndim=$DIMS\nvocab=$V\n"; close $ST;
# ---- EVAL: fold-sibling retrieval, same protocol as the refuted lens (chunk query vs chunk pool) ----
my (@sq,@sl,@sv);
for(my $ci=0;$ci<$NC && @sq<4000;$ci+=int($NC/4000)||1){
  my @cv=(0)x$DIMS;
  for my $p ($rowptr[$ci]..$rowptr[$ci+1]-1){ my $w=$colid[$p]; my $x=$val[$p];
    $cv[$_]+=$x*$U[$_][$w] for 0..$DIMS-1 }
  my $nn=0;$nn+=$_*$_ for @cv; next if $nn<1e-9; $nn=sqrt($nn);
  push @sq,[map{$_/$nn}@cv]; push @sl,$cpar[$ci];
}
my %plc; $plc{$_}++ for @sl;
my $hit=0; my $tries=0;
for(my $qi=7;$qi<@sq && $tries<300;$qi+=int(@sq/300)||1){
  next unless $plc{$sl[$qi]}>=2; $tries++;
  my $q=$sq[$qi]; my($best,$bi)=(-2,-1);
  for my $i (0..$#sq){ next if $i==$qi; my $c=0; my $f=$sq[$i];
    $c+=$f->[$_]*$q->[$_] for 0..$DIMS-1; if($c>$best){$best=$c;$bi=$i} }
  $hit++ if $sl[$bi] eq $sl[$qi];
}
printf "svd: fold-sibling retrieval P\@1 = %.3f (%d/%d)   [refuted apple-lens baseline = 0.020]\n",$tries?$hit/$tries:0,$hit,$tries;
PL
  ;;
bake)
  # BAKE THE LENS + LSH (Lane B, chip): apply lens.drop to the parent nanodex -> nanodex.lens.bin
  # (raw kept for relearning), then hyperplane LSH buckets (shadow geometry: L=10 tables x B=12
  # seeded planes) on the BAKED vectors -> nanodex.lsh. Weak-query scan goes full -> buckets.
  ND="$ROOT/index/nanodex"; NDC="$ROOT/index/nanodexc"
  [ -s "$ND/nanodex.bin" ] || { echo "coalesce bake: no nanodex" >&2; exit 69; }
  [ -s "$NDC/lens.pcs" ] || { echo "coalesce bake: no lens (run: coalesce lens)" >&2; exit 69; }
  perl /dev/stdin "$ND" "$NDC" <<'PL'
use strict; use warnings;
my($ND,$NDC)=@ARGV;
my %st; open my $S,'<',"$ND/stats"; while(<$S>){chomp;my($k,$v)=split/=/;$st{$k}=$v} close $S;
my($nrow,$d)=($st{rows},$st{dim}); my $row=4*$d;
open my $PC,'<',"$NDC/lens.pcs" or die; my @E; while(<$PC>){chomp; push @E,[split / /]} close $PC;
open my $DR,'<',"$NDC/lens.drop" or die; my $dl=<$DR>//''; chomp $dl; my @drop=grep{length}split / /,$dl; close $DR;
my @DE=map{$E[$_]}@drop;
# seeded hyperplanes (shadow geometry)
my($L,$B)=(10,12); my @PLANE;
for my $p (0..$L*$B-1){ my @r; for my $i (0..$d-1){ my $hh=($p*2654435761 + $i*40503 + 0x5CA1AB1E) % 0xFFFFFFFF; push @r, ((($hh>>16)&1)?1:-1) } $PLANE[$p]=\@r }
open my $BF,'<:raw',"$ND/nanodex.bin" or die;
open my $BO,'>:raw',"$ND/nanodex.lens.bin" or die;
open my $LO,'>',"$ND/nanodex.lsh.tmp" or die;
my $buf;
for(my $r=0;$r<$nrow;$r++){
  sysread($BF,$buf,$row)==$row or last;
  my @w=unpack("f$d",$buf);
  for my $ej (@DE){ my $dp=0; $dp+=$w[$_]*$ej->[$_] for 0..$d-1; $w[$_]-=$dp*$ej->[$_] for 0..$d-1 }
  my $nn=0;$nn+=$_*$_ for @w;$nn=sqrt($nn)||1;$_/=$nn for @w;
  print $BO pack("f*",@w);
  for my $t (0..$L-1){ my $key=0;
    for my $j (0..$B-1){ my $pl=$PLANE[$t*$B+$j]; my $dp=0; $dp+=$w[$_]*$pl->[$_] for 0..$d-1; $key=($key<<1)|($dp>=0?1:0) }
    print $LO "$t:$key $r\n" }
}
close $BF; close $BO; close $LO;
system("sort -k1,1 '$ND/nanodex.lsh.tmp' > '$ND/nanodex.lsh' && rm -f '$ND/nanodex.lsh.tmp'");
print "bake: $nrow rows lensed (dropped ",scalar(@drop)," PCs) + LSH L=$L B=$B\n";
PL
  ;;
lens)
  # THE CHAIN SUPERVISES ITS OWN LENS (chip.chain.brain): supervision = fold membership (clauses
  # of the SAME fold belong close; the chain's structure IS the labels — no external teacher).
  # Learn per-PC Fisher (between-fold/within-fold variance) over the clause manifold; the lens
  # downweights style/noise directions. Derived artifacts only: index/nanodexc/lens.{pcs,fisher,drop}.
  #   coalesce lens          learn + sweep + auto-pick Q (fold-retrieval P@1)
  ND="$ROOT/index/nanodexc"
  [ -s "$ND/nanodexc.bin" ] || { echo "coalesce lens: no nanodexc (run: coalesce nanodexc)" >&2; exit 69; }
  perl /dev/stdin "$ND" <<'PL'
use strict; use warnings;
my($ND)=@ARGV;
my $K=32; my $SAMPLE=4000; my $PCSAMPLE=1500; my $EVALQ=300;
open my $PR,'<',"$ND/nanodexc.par" or die; my @PAR=<$PR>; chomp @PAR; close $PR;
my %cnt; $cnt{$_}++ for @PAR;
my %st; open my $S,'<',"$ND/stats"; while(<$S>){chomp;my($k,$v)=split/=/;$st{$k}=$v} close $S;
my($nrow,$d)=($st{rows},$st{dim}); my $row=4*$d;
open my $BF,'<:raw',"$ND/nanodexc.bin" or die;
my (@X,@L); my $buf;
for(my $r=0;$r<$nrow && @X<$SAMPLE;$r++){
  my $p=$PAR[$r]; next unless $cnt{$p}>=4 && $cnt{$p}<=40;
  next if $r%3;
  sysseek($BF,$r*$row,0); sysread($BF,$buf,$row)==$row or last;
  push @X,[unpack("f$d",$buf)]; push @L,$p;
}
close $BF; my $n=@X;
print "lens: sample n=$n parents=",scalar(keys %{{map{($_=>1)}@L}}),"\n";
my @C; for(my $i=0;$i<$n && @C<$PCSAMPLE;$i+=int($n/$PCSAMPLE)||1){ push @C,$X[$i] }
my @E;
for my $e (0..$K-1){
  my @v=map{ (($_*2654435761+$e*131)%1000)/1000-0.5 }(0..$d-1);
  for my $it (0..15){ my @nv=(0)x$d;
    for my $x (@C){ my $dp=0; $dp+=$x->[$_]*$v[$_] for 0..$d-1; $nv[$_]+=$dp*$x->[$_] for 0..$d-1 }
    for my $pe (@E){ my $dp=0; $dp+=$nv[$_]*$pe->[$_] for 0..$d-1; $nv[$_]-=$dp*$pe->[$_] for 0..$d-1 }
    my $nn=0;$nn+=$_*$_ for @nv;$nn=sqrt($nn)||1;@v=map{$_/$nn}@nv; }
  push @E,[@v];
}
my @fisher;
for my $j (0..$K-1){
  my $ej=$E[$j]; my (%sum,%sq,%m);
  for my $i (0..$n-1){ my $x=$X[$i]; my $s=0; $s+=$x->[$_]*$ej->[$_] for 0..$d-1;
    $sum{$L[$i]}+=$s; $sq{$L[$i]}+=$s*$s; $m{$L[$i]}++ }
  my($wss,$bss,$gm,$np)=(0,0,0,0); my @means;
  for my $p (keys %m){ my $mu=$sum{$p}/$m{$p}; push @means,$mu; $gm+=$mu; $np++;
    $wss += $sq{$p}/$m{$p} - $mu*$mu }
  $gm/=$np; $bss += ($_-$gm)**2 for @means; $bss/=$np; $wss/=$np;
  $fisher[$j] = $wss>1e-9 ? $bss/$wss : 0;
}
my @ord=sort{ $fisher[$b]<=>$fisher[$a] } 0..$K-1;
print "lens: fisher(sorted) ",join(" ",map{sprintf"%.2f",$fisher[$_]}@ord),"\n";
sub filt{ my($x,$drop)=@_; my @w=@$x;
  for my $j (@$drop){ my $ej=$E[$j]; my $dp=0; $dp+=$w[$_]*$ej->[$_] for 0..$d-1; $w[$_]-=$dp*$ej->[$_] for 0..$d-1 }
  my $nn=0;$nn+=$_*$_ for @w;$nn=sqrt($nn)||1; [map{$_/$nn}@w] }
my @qidx; for(my $i=7;$i<$n && @qidx<$EVALQ;$i+=int($n/$EVALQ)||1){ push @qidx,$i }
my($bestQ,$bestA)=(0,-1); my %acc;
for my $Q (0,4,8,12,16){
  my @drop = $Q ? @ord[$K-$Q..$K-1] : ();
  my @F = map{ filt($_,\@drop) } @X;
  my $hit=0;
  for my $qi (@qidx){
    my $q=$F[$qi]; my($best,$bi)=(-2,-1);
    for my $i (0..$n-1){ next if $i==$qi; my $c=0; my $f=$F[$i];
      $c+=$f->[$_]*$q->[$_] for 0..$d-1; if($c>$best){$best=$c;$bi=$i} }
    $hit++ if $L[$bi] eq $L[$qi];
  }
  my $a=$hit/@qidx; $acc{$Q}=$a;
  printf "lens: Q=%2d dropped -> fold-retrieval P\@1 = %.3f (%d/%d)\n",$Q,$a,$hit,scalar(@qidx);
  if($a>$bestA){$bestA=$a;$bestQ=$Q}
}
open my $O,'>',"$ND/lens.pcs"; print $O join(" ",map{sprintf"%.6f",$_}@{$E[$_]}),"\n" for 0..$K-1; close $O;
open my $F2,'>',"$ND/lens.fisher"; print $F2 join(" ",map{sprintf"%.4f",$_}@fisher),"\n"; close $F2;
open my $D,'>',"$ND/lens.drop"; print $D join(" ",$bestQ?@ord[$K-$bestQ..$K-1]:()),"\n"; close $D;
printf "lens: PICKED Q=%d (P\@1=%.3f baseline=%.3f) -> lens.drop written\n",$bestQ,$bestA,$acc{0};
PL
  ;;
nanodexc)
  # CHUNK-LEVEL semantic tier (R5b): embed every CLAUSE (the max-chunk thesis — one distinctive
  # clause surfaces its fold), pool max-cos per parent at query time. Derived sidecar only.
  ND="$ROOT/index/nanodexc"; mkdir -p "$ND"
  EMBED="$ROOT/libexec/embed"; CORES=$(sysctl -n hw.ncpu 2>/dev/null || echo 8)
  CH="$IDXR/chunks.tsv"; [ -s "$CH" ] || { echo "coalesce nanodexc: no chunks.tsv" >&2; exit 69; }
  rm -f "$ND"/shard.*
  n=$(wc -l < "$CH" | tr -d ' '); per=$(( (n + CORES - 1) / CORES ))
  perl -e '
    my($cf,$per,$nd)=@ARGV; open my $C,"<:raw",$cf or die; my %PF; my %TF; my $nr=0;
    while(my $l=<$C>){ chomp $l; my($cid,$pidx,$t)=split /\t/,$l,3; $t//=""; my $s=int($nr++/$per);
      unless($PF{$s}){ open $PF{$s},">","$nd/shard.$s.par" or die; open $TF{$s},">:raw","$nd/shard.$s.txt" or die }
      $t=~s/\x0/ /g; print {$PF{$s}} "$pidx\n"; print {$TF{$s}} "$t\0"; }
  ' "$CH" "$per" "$ND"
  pids=""; for s in $(seq 0 $((CORES-1))); do
    [ -f "$ND/shard.$s.txt" ] || continue
    "$EMBED" < "$ND/shard.$s.txt" > "$ND/shard.$s.vec" 2>/dev/null & pids="$pids $!"
  done
  for p in $pids; do wait "$p"; done
  perl /dev/stdin "$ND" "$CORES" <<'PL'
use strict; use warnings; my($nd,$cores)=@ARGV;
my (@P,@RAW); my $miss=0;
for my $s (0..$cores-1){
  next unless -f "$nd/shard.$s.par";
  open my $HF,'<',"$nd/shard.$s.par" or die; my @pp=<$HF>; chomp @pp; close $HF;
  open my $VF,'<',"$nd/shard.$s.vec" or die; my $i=0;
  while(my $v=<$VF>){ chomp $v; my $p=$pp[$i++]; next unless defined $p;
    if($v eq 'MISS' || $v!~/ /){ $miss++; next }
    push @P,$p; push @RAW,$v; } close $VF; }
my $n=@P; die "nanodexc: no vectors" unless $n;
my @f0=split / /,$RAW[0]; my $d=@f0;
my @mu=(0)x$d; for my $r (@RAW){ my @w=split / /,$r; $mu[$_]+=$w[$_] for 0..$d-1 } $_/=$n for @mu;
my @S; for(my $i=0;$i<$n;$i+=37){ my @w=split / /,$RAW[$i]; $w[$_]-=$mu[$_] for 0..$d-1; push @S,\@w }
my @v=map{ (($_*2654435761)%1000)/1000-0.5 }(0..$d-1);
for my $it (0..17){ my @nv=(0)x$d;
  for my $x (@S){ my $dp=0; $dp+=$x->[$_]*$v[$_] for 0..$d-1; $nv[$_]+=$dp*$x->[$_] for 0..$d-1 }
  my $nn=0;$nn+=$_*$_ for @nv;$nn=sqrt($nn)||1;@v=map{$_/$nn}@nv; }
open my $M,'>',"$nd/nanodexc.mean"; print $M join(" ",map{sprintf"%.6f",$_}@mu),"\n"; close $M;
open my $E,'>',"$nd/nanodexc.eig";  print $E join(" ",map{sprintf"%.6f",$_}@v),"\n";  close $E;
open my $PO,'>',"$nd/nanodexc.par"; open my $BO,'>:raw',"$nd/nanodexc.bin";
for my $i (0..$n-1){ my @w=split / /,$RAW[$i];
  $w[$_]-=$mu[$_] for 0..$d-1;
  my $dp=0; $dp+=$w[$_]*$v[$_] for 0..$d-1; $w[$_]-=$dp*$v[$_] for 0..$d-1;
  my $nn=0;$nn+=$_*$_ for @w;$nn=sqrt($nn)||1; $_/=$nn for @w;
  print $PO "$P[$i]\n"; print $BO pack("f*",@w); }
close $PO; close $BO;
open my $ST,'>',"$nd/stats"; print $ST "rows=$n\ndim=$d\nmiss=$miss\n"; close $ST;
print "nanodexc: rows=$n dim=$d miss=$miss\n";
PL
  rm -f "$ND"/shard.*
  ;;
nanodex)
  # SEMANTIC SIDECAR (R5, derived — never the chain): blast-swarm embed every NANO parent on the
  # ANE (512-dim), then spectral transform (center + remove top-1 PC = de-anisotropize, the shadow
  # calibration) and pack unit vectors for the BFS scan. bits on chain; floats ONLY here.
  ND="$ROOT/index/nanodex"; mkdir -p "$ND"
  EMBED="$ROOT/libexec/embed"; CORES=$(sysctl -n hw.ncpu 2>/dev/null || echo 8)
  [ -s "$PARENTS" ] || { echo "coalesce nanodex: no parents.tsv (run: coalesce build)" >&2; exit 69; }
  # shard hashes + texts (truncate 1200 chars — embed cost bound), NUL-delimited per record
  rm -f "$ND"/shard.*; n=$(wc -l < "$PARENTS" | tr -d ' ')
  per=$(( (n + CORES - 1) / CORES ))
  # byte-safe sharder (raw mode — formals may carry non-UTF8 bytes; awk multibyte chokes)
  perl -e '
    my($pf,$per,$nd)=@ARGV; open my $P,"<:raw",$pf or die; my %HF; my %TF; my $nr=0;
    while(my $l=<$P>){ chomp $l; my($h,$t)=split /\t/,$l,2; $t//=""; my $s=int($nr++/$per);
      unless($HF{$s}){ open $HF{$s},">","$nd/shard.$s.hash" or die; open $TF{$s},">:raw","$nd/shard.$s.txt" or die }
      $t=substr($t,0,1200); $t=~s/\x0/ /g;
      print {$HF{$s}} "$h\n"; print {$TF{$s}} "$t\0"; }
  ' "$PARENTS" "$per" "$ND"
  # BLAST SWARM: one embed per shard, all cores
  pids=""; for s in $(seq 0 $((CORES-1))); do
    [ -f "$ND/shard.$s.txt" ] || continue
    "$EMBED" < "$ND/shard.$s.txt" > "$ND/shard.$s.vec" 2>/dev/null & pids="$pids $!"
  done
  for p in $pids; do wait "$p"; done
  # spectral transform + pack (streaming mean; top-1 PC power-iterated on a 1/7 sample)
  perl /dev/stdin "$ND" "$CORES" <<'PL'
use strict; use warnings; my($nd,$cores)=@ARGV;
my (@H,@RAW); my $miss=0;
for my $s (0..$cores-1){
  next unless -f "$nd/shard.$s.hash";
  open my $HF,'<',"$nd/shard.$s.hash" or die; my @hh=<$HF>; chomp @hh; close $HF;
  open my $VF,'<',"$nd/shard.$s.vec" or die; my $i=0;
  while(my $v=<$VF>){ chomp $v; my $h=$hh[$i++]; next unless defined $h;
    if($v eq 'MISS' || $v!~/ /){ $miss++; next }
    push @H,$h; push @RAW,$v; } close $VF; }
my $n=@H; die "nanodex: no vectors" unless $n;
my @f0=split / /,$RAW[0]; my $d=@f0;
my @mu=(0)x$d;
for my $r (@RAW){ my @w=split / /,$r; $mu[$_]+=$w[$_] for 0..$d-1 }
$_/=$n for @mu;
# top-1 PC on every-7th sample
my @S; for(my $i=0;$i<$n;$i+=7){ my @w=split / /,$RAW[$i]; $w[$_]-=$mu[$_] for 0..$d-1; push @S,\@w }
my @v=map{ (($_*2654435761)%1000)/1000-0.5 }(0..$d-1);
for my $it (0..17){ my @nv=(0)x$d;
  for my $x (@S){ my $dp=0; $dp+=$x->[$_]*$v[$_] for 0..$d-1; $nv[$_]+=$dp*$x->[$_] for 0..$d-1 }
  my $nn=0;$nn+=$_*$_ for @nv;$nn=sqrt($nn)||1;@v=map{$_/$nn}@nv; }
open my $M,'>',"$nd/nanodex.mean"; print $M join(" ",map{sprintf"%.6f",$_}@mu),"\n"; close $M;
open my $E,'>',"$nd/nanodex.eig";  print $E join(" ",map{sprintf"%.6f",$_}@v),"\n";  close $E;
open my $HO,'>',"$nd/nanodex.hash"; open my $BO,'>:raw',"$nd/nanodex.bin";
for my $i (0..$n-1){ my @w=split / /,$RAW[$i];
  $w[$_]-=$mu[$_] for 0..$d-1;
  my $dp=0; $dp+=$w[$_]*$v[$_] for 0..$d-1; $w[$_]-=$dp*$v[$_] for 0..$d-1;
  my $nn=0;$nn+=$_*$_ for @w;$nn=sqrt($nn)||1; $_/=$nn for @w;
  print $HO "$H[$i]\n"; print $BO pack("f*",@w); }
close $HO; close $BO;
open my $ST,'>',"$nd/stats"; print $ST "rows=$n\ndim=$d\nmiss=$miss\n"; close $ST;
print "nanodex: rows=$n dim=$d miss=$miss\n";
PL
  rm -f "$ND"/shard.*
  ;;
*) echo "coal {build|recall <query>|nanodex}" >&2; exit 64 ;;
esac
