  my $cw = $sem ? (1.3-$conf) : 0;                               # evidence reallocation: weak lexical -> the manifold speaks
  $fs{$h} = $conf*0.7*$bn + $cw*cosof($h) + 1e-9*$bn;            # tie -> lexical wins
}
my @frank=sort{ $fs{$b}<=>$fs{$a} } keys %fs;
unless(@frank){ print "laude: honest miss — nothing on the chain grounds that (coalesce)\n"; exit 0 }
my $mode=$sem?sprintf("bm25+spec conf=%.2f",$conf):"bm25 (lexical-only)";
my %rrf=%fs;   # keep downstream naming
if($K==1){
  # ---- LAMBDA DFS (attestation): the surfaced fold must PROVE its spine — sha256(prev++formal)==# .
  # Unproven = dark, take the next candidate. Nothing surfaces unattested (0xFF-or-dark).
  my $shown=0;
  for my $c (0..($#frank>4?4:$#frank)){
    my $h=$frank[$c]; next unless $h=~/^[0-9a-f]{64}$/;
    my $tsv=qx(grep -m1 -F '"payload_hash":"$h"' '$LED' | jq -r '(.prev_hash//"") + " " + (((.payload.formal // (.payload | del(.category?) | tostring)) // "")|\@base64)');
    chomp $tsv; my($prevh,$fb64)=split / /,$tsv,2;
    next unless defined $fb64 && $prevh=~/^[0-9a-f]{64}$/;
    my $formal=decode_base64($fb64);
    next unless sha256_hex($prevh.$formal) eq $h;             # DFS spine fails -> dark
    # HONESTY FLOOR (R6, recalibrated: reject NONSENSE, not TRUTH). Nonsense = weak fusion AND no
    # overlap AND weak cos. A real query (even abstract/paraphrase) has EITHER real term-overlap OR a
    # well-separated rank-1 OR a strong cos. Attest if ANY holds; miss only when ALL are weak.
    my %ft; $ft{$_}=1 for toks($formal);
    my @content=grep{ ($df{$_}//0) < $N/20 } @qk;
    my $cov = @content ? (grep{$ft{$_}} @content)/@content : 1;
    # rank-1 separation: fused score vs the field's runner-up. Nonsense = flat field (sep~1.0);
    # a real query has real term-coverage OR a well-separated rank-1. Cos is NOT trusted (anisotropic
    # manifold gives nonsense a false ~0.58 — that was the leak; the lens is ranking-only, not attest).
    my $sep = ($c==0 && @frank>1 && $rrf{$frank[1]}>0) ? $rrf{$h}/$rrf{$frank[1]} : 1;
    # compound floor (2026-07-10 burn wf_906efb04 caught cov=0.50 sep=1.07 spurious attest on
    # 'purple elephant quantum cheese' — one common-token hit): strong coverage OR strong
    # separation OR moderate-both; half-coverage alone with a flat field is nonsense.
    unless ($cov>0.50 || $sep>=1.30 || ($cov>=0.30 && $sep>=1.15)){ next }   # all weak → honest miss
    my $p=$h2p{$h}; my $fm=substr($pfm[$p]//"",0,260);
    printf "laude attests (%s %.4f cov=%.2f sep=%.2f dfs=ok): %s\n", $mode, $rrf{$h}, $cov, $sep, $fm; $shown=1; last;
  }
  print "laude: honest miss — nothing on the chain grounds that (floor: coverage+cos)\n" unless $shown;
}
else { for my $r (0..$K-1){ last if $r>=@frank; my $h=$frank[$r]; my $p=$h2p{$h};
  printf "#%d rrf=%.4f magic://%s :: %s\n", $r+1,$rrf{$h},substr($h,0,16), substr($pfm[$p]//"",0,90) } }
PL
  ;;
hashx)
  # HASH-POWER RECALL (bytewise agency): turn the O(corpus) postings SCAN into O(query-terms) SEEK.
  # sort postings by term -> byte-offset map term->(offset,len). Recall seeks ONLY the query terms'
  # spans instead of streaming all ~2.4M lines. The term IS the key; recall becomes hash-addressed.
  # P1: post.tsv exists only right after a FULL build (the cold path). The steady state has no
  # post.tsv — the inc appends to post.tail and hashx delegates to compact (merge, no full sort).
  [ -s "$IDX/post.tsv" ] || exec "$0" compact
  # ATOMIC (C10): sort→tmp, build offset-map from tmp→tmp, then mv both. A concurrent native recall
  # never reads a half-written file (each mv is atomic); the native path also has a full-scan fallback.
  LC_ALL=C sort -k1,1 -s "$IDX/post.tsv" > "$IDX/post.sorted.tmp"
  perl -e '
    my($in,$off)=@ARGV; open my $I,"<:raw",$in or die; open my $O,">",$off or die;
    my $pos=0; my $cur=""; my $start=0;
    while(my $l=<$I>){ my $t=substr($l,0,index($l,"\t"));
      if($t ne $cur){ print $O "$cur\t$start\t",($pos-$start),"\n" if $cur ne ""; $cur=$t; $start=$pos }
      $pos+=length($l); }
    print $O "$cur\t$start\t",($pos-$start),"\n" if $cur ne "";
  ' "$IDX/post.sorted.tmp" "$IDX/term.off.tmp"
  mv "$IDX/post.sorted.tmp" "$IDX/post.sorted"; mv "$IDX/term.off.tmp" "$IDX/term.off"
  # the sorted map now HOLDS every posting — post.tsv was only ever sort input (141MB duplicate),
  # and any tail predates this full rebuild. Drop both; the inc regrows the tail from here.
  rm -f "$IDX/post.tsv" "$IDX/post.tail" "$IDX/post.tail.c"
  # BAKE (P2): refresh the mmap sidecars — the read path is open+mmap+seek, zero parse.
  "$ROOT/libexec/bake" "$IDX" "$PARENTS" >/dev/null 2>&1 || true
  echo "hashx · $(wc -l < "$IDX/term.off" | tr -d ' ') terms keyed · $(wc -c < "$IDX/post.sorted" | tr -d ' ') bytes seekable"
  ;;
compact)
  # COMPACT (P1): fold the delta tail into the sorted map — sort ONLY the tail, then a linear
  # sort -m merge (no 141MB re-sort, ever). Locked (one compactor), snapshot (post.tail.c stays
  # readable by bm25 until the merge publishes), atomic (tmp+mv).
  [ -s "$IDX/post.tail" ] || { echo "compact: no tail — nothing to fold"; exit 0; }
  [ -s "$IDX/post.sorted" ] || { echo "compact: no post.sorted (run: coalesce build)" >&2; exit 69; }
  CLOCK="$IDX/.compact.lock"
  if ! mkdir "$CLOCK" 2>/dev/null; then echo "compact: another compactor holds $CLOCK, skipping" >&2; exit 0; fi
  trap 'rmdir "$CLOCK" 2>/dev/null' EXIT INT TERM
  mv "$IDX/post.tail" "$IDX/post.tail.c"
  LC_ALL=C sort -k1,1 -s "$IDX/post.tail.c" > "$IDX/post.tail.sorted"
  LC_ALL=C sort -m -k1,1 -s "$IDX/post.sorted" "$IDX/post.tail.sorted" > "$IDX/post.sorted.tmp"
  perl -e '
    my($in,$off)=@ARGV; open my $I,"<:raw",$in or die; open my $O,">",$off or die;
    my $pos=0; my $cur=""; my $start=0;
    while(my $l=<$I>){ my $t=substr($l,0,index($l,"\t"));
      if($t ne $cur){ print $O "$cur\t$start\t",($pos-$start),"\n" if $cur ne ""; $cur=$t; $start=$pos }
      $pos+=length($l); }
    print $O "$cur\t$start\t",($pos-$start),"\n" if $cur ne "";
  ' "$IDX/post.sorted.tmp" "$IDX/term.off.tmp"
  mv "$IDX/post.sorted.tmp" "$IDX/post.sorted"; mv "$IDX/term.off.tmp" "$IDX/term.off"
