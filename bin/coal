PL
  echo "coalesce built · parents=$np · $(cat "$IDX/stats" | tr '\n' ' ')"
  # SEEK MAP RIDES THE BUILD (P1): a full build re-emits post.tsv from zero, so the sorted map is
  # regenerated here, inline (the build already paid the big scan) — the beat never re-sorts.
  "$0" hashx || true
